[run]
# The certified coverage scope is production scheduler/predictor code only.
source =
    python/predictor
    python/scheduler
omit =
    # Benchmark comparison and visualization entry points generate reports;
    # they are validated separately and are not production serving code.
    python/benchmark/compare.py
    python/benchmark/plots.py
    */audit_scripts/*
    */tests/*

[report]
precision = 2
show_missing = True
skip_covered = False
fail_under = 91.58

[html]
directory = coverage_html
